{
  "_comment": "通用代码开发场景 — 任何包含 src/、package.json、pyproject.toml 等的开发项目",
  "name": "代码开发项目",
  "detect": {
    "dirs": ["src/", "tests/", "lib/"],
    "files": ["package.json", "pyproject.toml", "go.mod", "Cargo.toml", "CMakeLists.txt"],
    "keywords_in_claude_md": ["src", "test", "build", "deploy"]
  },
  "anatomy_healthy": {
    "max_lines": 600,
    "max_files": 500,
    "max_size_kb": 30
  },
  "sessions_healthy": {
    "max_count": 50,
    "max_age_days": 30,
    "max_total_mb": 5
  },
  "dirs_should_track": [
    "src/",
    "tests/",
    "lib/",
    ".claude/skills/",
    ".claude/rules/",
    "docs/",
    "scripts/"
  ],
  "dirs_should_not_track": [
    "node_modules/",
    "venv/",
    ".venv/",
    "env/",
    ".env/",
    "dist/",
    "build/",
    ".next/",
    ".nuxt/",
    "coverage/",
    "__pycache__/",
    ".cache/",
    "target/",
    ".turbo/",
    ".vercel/",
    ".netlify/",
    ".output/",
    ".claudian/sessions/",
    ".git/"
  ],
  "expected_excludes": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "venv",
    ".venv",
    "env",
    "coverage",
    "__pycache__",
    ".cache",
    "target",
    ".next",
    ".nuxt"
  ],
  "waste_sources_priority": [
    { "type": "dependency_leak", "description": "node_modules / venv / vendor 被 anatomy 追踪" },
    { "type": "stale_sessions", "description": "超过 30 天的会话文件未清理" },
    { "type": "build_artifact_pollution", "description": "dist/build/.next 等编译产物被追踪" },
    { "type": "claude_md_bloat", "description": "CLAUDE.md 体积过大" },
    { "type": "ineffective_excludes", "description": "排除规则声明了但实际未生效" }
  ]
}
