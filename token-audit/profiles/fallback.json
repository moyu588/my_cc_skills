{
  "_comment": "通用兜底场景 — 不熟悉项目类型时的保守检测策略，仅报告明显异常",
  "name": "通用检测",
  "detect": {
    "dirs": [],
    "files": ["CLAUDE.md"],
    "keywords_in_claude_md": []
  },
  "anatomy_healthy": {
    "max_lines": 500,
    "max_files": 400,
    "max_size_kb": 25
  },
  "sessions_healthy": {
    "max_count": 40,
    "max_age_days": 60,
    "max_total_mb": 5
  },
  "dirs_should_track": [
    ".claude/skills/",
    ".claude/rules/"
  ],
  "dirs_should_not_track": [
    "node_modules/",
    "venv/",
    ".venv/",
    "env/",
    ".env/",
    "dist/",
    "build/",
    "__pycache__/",
    ".git/"
  ],
  "expected_excludes": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "venv",
    ".venv",
    "env",
    "__pycache__"
  ],
  "waste_sources_priority": [
    { "type": "dependency_leak", "description": "node_modules / venv 等依赖目录被 anatomy 追踪" },
    { "type": "stale_sessions", "description": "超过 60 天的会话文件未清理" },
    { "type": "anatomy_bloat", "description": "anatomy.md 体积超过健康阈值" },
    { "type": "conflicted_files", "description": "同步冲突文件残留" },
    { "type": "claude_md_bloat", "description": "CLAUDE.md 体积过大" }
  ]
}
